# 키가 없어도 앱은 돌아간다 — 검색은 내장 샘플 레시피로 동작한다.
# 키를 넣으면 진짜 AI 검색 + 실제 사진으로 자동 전환된다. 발급 방법: docs/GET-KEYS.md
# .env.local 로 복사해서 값을 채운다:  cp .env.local.example .env.local

# Google Gemini API 키 — 레시피 검색(구글 검색 그라운딩) (비밀, 서버 전용)
GEMINI_API_KEY=

# (선택) 사진 폴백용 — 그라운딩 출처 페이지에 사진(og:image)이 없을 때만 사용.
# 네이버 검색 API (이미지). 둘 다 넣어야 동작. 없으면 사진 없이 표시. (비밀, 서버 전용)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
